---
import Layout from "../layouts/Page.astro";

const isSuccess = Astro.url.searchParams.get("success") === "true";
---

<Layout
  title="Contattaci"
  description=""
  pubDate={new Date("2019-04-28T00:00:00.000Z")}
  draft={false}
>
  <section class="contact-card">
    <div
      class="success-banner"
      id="success-banner"
      role="status"
      aria-live="polite"
      hidden={!isSuccess}
    >
      <span class="success-icon" aria-hidden="true">✓</span>
      <div>
        <strong>Messaggio inviato con successo.</strong>
        <p>Grazie per averci scritto. Ti risponderemo al più presto.</p>
      </div>
      <button
        type="button"
        class="dismiss-button"
        id="dismiss-success-banner"
        aria-label="Chiudi messaggio"
      >
        ×
      </button>
    </div>

    <h2>Scrivici</h2>
    <p>Compila il modulo e ti risponderemo il prima possibile.</p>

    <!-- // Styling Requires Tailwind CSS -->
    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      id="form"
      class="needs-validation"
      data-astro-reload
      novalidate
    >
      <input
        type="hidden"
        name="access_key"
        value="f820fa57-ede8-4733-bc10-152d3141855d"
      />
      <input
        type="hidden"
        name="subject"
        value="Contatto dal sito web bandavivaldi.it"
      />

      <input
        type="checkbox"
        class="hidden"
        style="display:none"
        name="botcheck"
      />

      <div class="field-group">
        <label for="email">Email</label>
        <input
          id="email_address"
          type="email"
          name="email"
          placeholder="La tua email"
          required
          class="w-full px-4 py-3 border placeholder:text-slate-400 rounded-md outline-none focus:ring-4 border-slate-300 focus:border-slate-600 ring-slate-100"
        />
        <div class="empty-feedback text-red-400 text-sm mt-1">
          Please provide your email address.
        </div>
        <div class="invalid-feedback text-red-400 text-sm mt-1">
          Please provide a valid email address.
        </div>
      </div>

      <div class="field-group">
        <label for="message">Messaggio</label>
        <textarea
          name="message"
          required
          placeholder="Your Message"
          class="w-full px-4 py-3 border placeholder:text-slate-400 rounded-md outline-none h-36 focus:ring-4 border-slate-300 focus:border-slate-600 ring-slate-100"
        ></textarea>
        <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">
          Please enter your message.
        </div>
      </div>

      <button type="submit" class="submit-button">Invia</button>

      <div id="result" class="mt-3 text-center"></div>
    </form>

    <script is:inline>
      document.addEventListener(
        "DOMContentLoaded",
        () => {
          const form = document.getElementById("form");
          const result = document.getElementById("result");
          const successBanner = document.getElementById("success-banner");
          const dismissButton = document.getElementById("dismiss-success-banner");

          const showSuccessBanner = () => {
            if (successBanner) {
              successBanner.hidden = false;
              successBanner.scrollIntoView({ behavior: "smooth", block: "start" });
            }
          };

          const hideSuccessBanner = () => {
            if (successBanner) {
              successBanner.hidden = true;
            }
          };

          if (dismissButton) {
            dismissButton.addEventListener("click", hideSuccessBanner);
          }

          form.addEventListener("submit", function (e) {
            e.preventDefault();
            form.classList.add("was-validated");
            if (!form.checkValidity()) {
              form.querySelectorAll(":invalid")[0].focus();
              return;
            }
            const formData = new FormData(form);
            const object = Object.fromEntries(formData);
            const json = JSON.stringify(object);

            result.innerHTML = "Invio in corso...";
            result.className = "mt-3 text-center";
            hideSuccessBanner();

            fetch("https://api.web3forms.com/submit", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
              },
              body: json,
            })
              .then(async (response) => {
                const payload = await response.json();
                const isSuccess = response.ok && payload.success !== false;

                if (isSuccess) {
                  result.className = "mt-3 text-center text-green-600";
                  result.innerHTML = "✔️ Messaggio inviato con successo.";
                  showSuccessBanner();
                } else {
                  result.className = "mt-3 text-center text-red-600";
                  result.innerHTML = "❌ Si è verificato un errore.";
                }
              })
              .catch((error) => {
                console.log(error);
                result.className = "mt-3 text-center text-red-600";
                result.innerHTML = "❌ Si è verificato un errore durante l'invio.";
              })
              .then(function () {
                form.reset();
                form.classList.remove("was-validated");
                setTimeout(() => {
                  result.style.display = "none";
                }, 5000);
              });
          });
        },
        { once: true },
      );
    </script>
  </section>

</Layout>


<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
  .contact-card {
    max-width: 640px;
    margin: 2rem auto;
    padding: 2rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
  }

  .success-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1rem 1rem 0.9rem;
    border: 1px solid #bbf7d0;
    border-radius: 14px;
    background: #f0fdf4;
    color: #166534;
  }

  .success-banner[hidden] {
    display: none;
  }

  .success-icon {
    display: inline-grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 999px;
    background: #22c55e;
    color: white;
    font-weight: 700;
    flex-shrink: 0;
  }

  .success-banner p {
    margin: 0.2rem 0 0;
    color: #166534;
  }

  .dismiss-button {
    margin-left: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: #166534;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
  }

  .submit-button {
    margin-top: 2rem;
    align-self: flex-start;
    padding: 0.9rem 1.3rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: white;
    font-weight: 700;
    cursor: pointer;
    min-width: 200px;
  }

  .contact-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.6rem;
  }

  .contact-card p {
    margin: 0 0 1.25rem;
    color: #475569;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-weight: 600;
    color: #0f172a;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    font: inherit;
    background: #fff;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.16);
  }

  button {
    align-self: flex-start;
    padding: 0.9rem 1.3rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: white;
    font-weight: 700;
    cursor: pointer;
  }

  button:hover {
    background: linear-gradient(135deg, #1d4ed8, #1e40af);
  }

  .note {
    margin-top: 1rem;
    text-align: center;
    color: #64748b;
  }
</style>
