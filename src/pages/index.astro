---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const slideshowImages = Object.values(
	import.meta.glob('../assets/slideshow/*.{jpg,jpeg,png,webp,avif}', { eager: true })
).map((image) => (image as { default: ImageMetadata }).default);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="slideshow" aria-label="Slideshow della Banda Antonio Vivaldi">
				<div class="slideshow-track">
					{slideshowImages.map((image, index) => (
						<div class:list={["slideshow-slide", index === 0 && 'is-active']} class="slideshow-slide">
							<Image
								src={image}
								alt="Foto della Banda Antonio Vivaldi"
								class="slideshow-image"
								loading={index === 0 ? 'eager' : 'lazy'}
							/>
						</div>
					))}
				</div>
				<div class="slideshow-controls" aria-label="Controlli slideshow">
					{slideshowImages.map((_, index) => (
						<button
							class:list={['slide-dot', index === 0 && 'is-active']}
							data-index={index}
							aria-label={`Vai alla slide ${index + 1}`}
						></button>
					))}
				</div>
			</section>

			<i>
				La <strong>Banda Antonio Vivaldi</strong> è lieta di conoscerti.
			</i>

			<p>
				In questo sito trovi foto, contenuti, informazioni sulla nostra
				banda. Speriamo di fare colpo!
			</p>

			<i>Pronto per altre informazioni?</i>

			<p>
				Scopri di più su di noi. Vieni a una nostra prova o concerto.
				Diventa socio.
			</p>

			<p><a href="/contattaci/">Scrivici, ci fa piacere!</a></p>
		</main>
		<Footer />

		<script>
			const slides = Array.from(document.querySelectorAll('.slideshow-slide'));
			const dots = Array.from(document.querySelectorAll('.slide-dot'));

			let currentIndex = 0;

			function showSlide(index: number) {
				currentIndex = index;

				for (let i = 0; i < slides.length; i++) {
					slides[i].classList.toggle('is-active', i === currentIndex);
					dots[i].classList.toggle('is-active', i === currentIndex);
				}
			}

			if (slides.length > 0) {
				showSlide(0);

				setInterval(() => {
					showSlide((currentIndex + 1) % slides.length);
				}, 5000);

				dots.forEach((dot) => {
					dot.addEventListener('click', () => {
						showSlide(Number(dot.dataset.index));
					});
				});
			}
		</script>
	</body>
</html>

<style>
	main {
		padding: 0 1em 3em;
	}

	.slideshow {
		position: relative;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		overflow: hidden;
		background: #0f172a;
		margin-bottom: 1rem;
	}

	.slideshow-track {
		position: relative;
		height: 420px;
	}

	.slideshow-slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.8s ease;
	}

	.slideshow-slide.is-active {
		opacity: 1;
	}

	.slideshow-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.slideshow-controls {
		position: absolute;
		bottom: 1rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.6rem;
		z-index: 2;
	}

	.slide-dot {
		width: 0.75rem;
		height: 0.75rem;
		padding: 0;
		border: 2px solid #ffffff;
		border-radius: 999px;
		background: transparent;
		cursor: pointer;
	}

	.slide-dot.is-active {
		background: #ffffff;
	}
</style>
